# HRMS — Apache Configuration
# Works on Windows XAMPP 8.x and Linux/macOS Apache 2.4+

Options -Indexes

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Block sensitive file types (Apache 2.4 syntax)
<FilesMatch "\.(sql|log|env|sh|bak)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# Prevent PHP execution in uploads folder
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^uploads/.*\.(php|php5|phtml|phar|cgi|pl)$ - [F,L]
</IfModule>
