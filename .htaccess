# HRMS Apache Configuration
# Compatible with Windows XAMPP and Linux/macOS Apache

Options -Indexes

# Security Headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Block sensitive file types
<FilesMatch "\.(sql|log|env|ini|sh|bak|json)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Prevent PHP execution inside uploads
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^uploads/.*\.(php|php5|phtml|pl|py|cgi)$ - [F,L]
</IfModule>

# URL Rewriting
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /HRMS/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
</IfModule>

# PHP Settings — PHP 7.x as Apache module (Linux / macOS XAMPP)
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 12M
    php_value max_execution_time 300
    php_value memory_limit 256M
    php_flag display_errors Off
    php_flag log_errors On
    php_value session.gc_maxlifetime 7200
</IfModule>

# PHP Settings — PHP 8.x as Apache module (Windows XAMPP 8.x)
<IfModule mod_php8.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 12M
    php_value max_execution_time 300
    php_value memory_limit 256M
    php_flag display_errors Off
    php_flag log_errors On
    php_value session.gc_maxlifetime 7200
</IfModule>

# If PHP runs as FastCGI/CGI, set these values in php.ini instead.
